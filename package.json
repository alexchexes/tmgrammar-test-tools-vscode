{
  "name": "vscode-tmgrammar-test-tools",
  "displayName": "TM Grammar Test Tools",
  "description": "POC VS Code extension for inserting caret assertions into TextMate syntax tests.",
  "version": "0.0.1",
  "publisher": "local",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:tmGrammarTestTools.insertCaretAssertions",
    "onCommand:tmGrammarTestTools.insertCaretAssertionsFull",
    "onCommand:tmGrammarTestTools.insertCaretAssertionsMinimal"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tmGrammarTestTools.insertCaretAssertions",
        "title": "TM Grammar Test Tools: Insert Caret Assertions For Current Line"
      },
      {
        "command": "tmGrammarTestTools.insertCaretAssertionsFull",
        "title": "TM Grammar Test Tools: Insert Caret Assertions For Current Line (Full)"
      },
      {
        "command": "tmGrammarTestTools.insertCaretAssertionsMinimal",
        "title": "TM Grammar Test Tools: Insert Caret Assertions For Current Line (Minimal)"
      }
    ],
    "configuration": {
      "title": "TM Grammar Test Tools",
      "properties": {
        "tmGrammarTestTools.configPath": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "Optional path to the grammar package.json used to load TextMate grammars. Relative paths resolve from the active document's workspace folder."
        },
        "tmGrammarTestTools.grammarProvider.command": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "Optional shell command that prints grammar file paths for the active document. Supports JSON output or newline-separated paths."
        },
        "tmGrammarTestTools.grammarProvider.cwd": {
          "type": "string",
          "default": "${projectRoot}",
          "scope": "resource",
          "description": "Working directory for tmGrammarTestTools.grammarProvider.command. Supports ${projectRoot}, ${workspaceFolder}, ${file}, ${fileDirname}, and ${fileBasename}."
        },
        "tmGrammarTestTools.grammarProvider.timeoutMs": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "scope": "resource",
          "description": "Timeout in milliseconds for tmGrammarTestTools.grammarProvider.command."
        },
        "tmGrammarTestTools.scopeMode": {
          "type": "string",
          "enum": [
            "full",
            "minimal"
          ],
          "default": "full",
          "scope": "resource",
          "description": "Controls whether generated assertions use exact full scope stacks or a reduced minimal form."
        },
        "tmGrammarTestTools.compactRanges": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "When enabled, merge disjoint caret ranges that share the same rendered scope list into a single assertion line when the syntax allows it."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "compile:test": "tsc -p ./tsconfig.test.json",
    "test": "npm run compile:test && node --test out-test/test/*.test.js",
    "watch": "tsc -w -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "vscode-oniguruma": "^1.5.1",
    "vscode-textmate": "^7.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.5.4",
    "vscode-tmgrammar-test": "0.1.3"
  }
}
